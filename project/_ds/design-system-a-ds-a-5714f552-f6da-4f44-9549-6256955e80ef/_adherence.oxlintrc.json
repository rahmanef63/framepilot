        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='placement'] > Literal[value!=/^(?:top|right|bottom|left)$/]",
        "message": "<Tooltip> placement must be one of 'top' | 'right' | 'bottom' | 'left'."
