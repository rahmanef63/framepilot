      {
        "selector": "JSXOpeningElement[name.name='CommandSearch'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|variant|value|onChange|onFocus|onBlur|style|key|ref|className|style|children)$/]",
        "message": "<CommandSearch> doesn't accept that prop. Declared props: placeholder, variant, value, onChange, onFocus, onBlur, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandSearch'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:search|input)$/]",
        "message": "<CommandSearch> variant must be one of 'search' | 'input'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContextMenu'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|glyph|align|width|style|key|ref|className|style|children)$/]",
        "message": "<ContextMenu> doesn't accept that prop. Declared props: items, glyph, align, width, style."
