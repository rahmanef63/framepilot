{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/content/**",
              "components/feedback/**",
              "components/layout/**",
              "components/navigation/**",
              "components/overlay/**",
              "ui_kits/design-platform/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Inter|JetBrains Mono|Source Serif 4))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Inter, JetBrains Mono, Source Serif 4."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppShell'] > JSXAttribute > JSXIdentifier[name!=/^(?:rail|sidebar|panel|overlays|theme|preset|accent|children|style|key|ref|className|style|children)$/]",
        "message": "<AppShell> doesn't accept that prop. Declared props: rail, sidebar, panel, overlays, theme, preset, accent, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppShell'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<AppShell> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|size|variant|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, size, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:user|team)$/]",
        "message": "<Avatar> variant must be one of 'user' | 'team'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Backdrop'] > JSXAttribute > JSXIdentifier[name!=/^(?:onClick|dark|style|key|ref|className|style|children)$/]",
        "message": "<Backdrop> doesn't accept that prop. Declared props: onClick, dark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|new|highlight|outline)$/]",
        "message": "<Badge> tone must be one of 'default' | 'new' | 'highlight' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Breadcrumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:path|onBack|style|key|ref|className|style|children)$/]",
        "message": "<Breadcrumb> doesn't accept that prop. Declared props: path, onBack, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|children|disabled|onClick|type|title|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, children, disabled, onClick, type, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|ghost|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'ghost' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|meta|badge|ratio|thumbCaption|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, meta, badge, ratio, thumbCaption, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Carousel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|gap|pad|style|key|ref|className|style|children)$/]",
        "message": "<Carousel> doesn't accept that prop. Declared props: children, gap, pad, style."
      },
