        "selector": "JSXOpeningElement[name.name='CloseButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:onClick|title|variant|style|key|ref|className|style|children)$/]",
        "message": "<CloseButton> doesn't accept that prop. Declared props: onClick, title, variant, style."
      },
