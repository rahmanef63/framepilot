# framepilot — environment template. Copy to .env.local and fill in.
# NEVER commit real secrets — .env.local is gitignored; only this template is tracked.

# ── Next.js (.env.local) ────────────────────────────────────────────────────

# Convex deployment URL — PUBLIC (shipped in the client bundle, non-sensitive).
# `npx convex dev` prints this the first time it provisions a dev deployment.
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud

# Convex deploy key — SECRET. Used by `npx convex deploy` (and Dokploy). Never
# expose it and never give it a NEXT_PUBLIC_ prefix.
CONVEX_DEPLOY_KEY=

# ── Convex deployment (set with `npx convex env set`, NOT in .env.local) ──────
# These live on the Convex deployment, not in the Next.js env:
#
#   ADMIN_EMAILS          comma-separated allowlist for requireAdmin() (convex/lib.ts)
#   JWT_PRIVATE_KEY, JWKS auth signing keys — run `npx @convex-dev/auth` once to set them
#   CONVEX_SITE_URL       provided automatically by the Convex runtime
ADMIN_EMAILS=

# ── Build-injected (do NOT set manually) ─────────────────────────────────────
# NEXT_PUBLIC_BUILD_ID is stamped at build time by the Dockerfile
# (NEXT_PUBLIC_BUILD_ID=$(date +%s)) and read by the update-toast / build-id route.
