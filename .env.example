# framepilot — environment template (rr convention). Copy to .env.local and fill in.
# NEVER commit real secrets — .env.local is gitignored; only this template is tracked.

# Convex deployment URL — PUBLIC (shipped in the client bundle, non-sensitive).
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud

# Convex deploy key — SECRET. Used by `npx convex deploy`. Never expose / never prefix NEXT_PUBLIC_.
CONVEX_DEPLOY_KEY=

# Admin allowlist for requireAdmin() — server-side only, comma-separated emails.
ADMIN_EMAILS=
